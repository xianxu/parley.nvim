{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": false
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/parallel-checks.sh --hook-gate"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/parallel-checks.sh --hook-gate"
          }
        ]
      }
    ]
  }
}
