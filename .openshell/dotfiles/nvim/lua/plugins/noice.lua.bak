return {
  "folke/noice.nvim",
  event = "VeryLazy",
  dependencies = {
    "MunifTanjim/nui.nvim",
    -- Optional but recommended for pretty notifications
    "rcarriga/nvim-notify",
  },
  opts = {
    -- Good defaults
    presets = {
      bottom_search = true,         -- use a bottom cmdline for search
      command_palette = true,       -- position cmdline+popupmenu together
      long_message_to_split = true, -- long messages go to a split
      inc_rename = false,           -- disable if you don't use inc-rename
      lsp_doc_border = true,        -- adds a border to hover/signature
    },
    lsp = {
      progress = { enabled = true },
      hover = { enabled = true },
      signature = { enabled = true },
      -- (Optional) improve markdown rendering in LSP messages
      override = {
        ["vim.lsp.util.convert_input_to_markdown_lines"] = true,
        ["vim.lsp.util.stylize_markdown"] = true,
        ["cmp.entry.get_documentation"] = true,
      },
    },
    cmdline = {
      enabled = true,
      view = "cmdline_popup", -- compact popup
      format = {
        cmdline = { icon = "" },
        search_down = { kind = "search", pattern = "^/", icon = " ", view = "cmdline" },
        search_up   = { kind = "search", pattern = "^%?", icon = " ", view = "cmdline" },
      },
    },
    messages = {
      enabled = true,
      view_search = false, -- keep search count near cursor (optional)
    },
    routes = {
      { filter = { event = "notify", min = vim.log.levels.INFO } },
      -- Example: hide “written” and small noise
      { filter = { event = "msg_show", kind = "", find = "written" }, opts = { skip = true } },
      { filter = { event = "msg_show", kind = "search_count" }, opts = { skip = true } },
    },
    views = {
      cmdline_popup = {
        border = { style = "rounded" },
        position = { row = "35%", col = "50%" },
        size = { width = 60, height = "auto" },
      },
      popupmenu = { backend = "nui", border = { style = "rounded" } },
    },
  },
  config = function(_, opts)
    require("noice").setup(opts)
    -- Optional: use nvim-notify as the default notifier
    local ok, notify = pcall(require, "notify")
    if ok then
      vim.notify = notify
    end
  end,
}
