# Ariadne Base Layer Manifest
# Lists all portable paths that setup.sh will symlink/scaffold into consuming repos.
# Lines starting with # are comments. Empty lines are ignored.
#
# Format:
#   <action> <source-path> [<target-path>]
#
# Actions:
#   symlink   — create symlink from target repo to ariadne path
#   scaffold  — create empty directory structure in target repo
#   copy      — copy file (for files that need local modification)
#   merge     — JSON merge (settings.ariadne.json layered under settings.local.json)
#   touch     — create empty file if missing (no source needed)

# ── Constitution ──────────────────────────────────────────────────────────────
symlink   AGENTS.md
symlink   CLAUDE.md

# ── Claude Code settings ──────────────────────────────────────────────────────
merge     .claude/settings.ariadne.json        .claude/settings.json

# ── Skills ──────────────────────────────────────────────────────────────────────
# NOTE: Superpowers and other adapted skills are NOT in base.manifest.
# They are managed per-repo via /construct adapt + /construct promote.
# Only core and local-origin skills are symlinked by setup.sh.

# NOTE: construct skill is ariadne-internal, not exported to target repos.

# Local-origin skills are managed by sync-local-skills.sh (SessionStart hook),
# which reads the prefix from construct/config.json. Not hardcoded here.
scaffold  .claude/skills

# ── Makefile system ───────────────────────────────────────────────────────────
symlink   Makefile.workflow
symlink   scripts/lib.sh
symlink   scripts/issue-sync.sh
symlink   scripts/parallel-checks.sh
symlink   scripts/pre-merge-checks.sh

# ── Construct system ──────────────────────────────────────────────────────────
symlink   construct/scripts/sync-local-skills.sh
symlink   construct/local
symlink   construct/adapted
copy      construct/config.json

# ── Data prototypes (typed markdown documents, used by xx-data skill) ─────────
# Shared prototypes propagate via symlink. Project-local overrides at
# <repo>/data/<name>.md are opt-in and not scaffolded.
symlink   construct/data

# ── Directory conventions (scaffold empty dirs) ───────────────────────────────
scaffold  workshop/issues
scaffold  workshop/history
scaffold  workshop/plans
scaffold  workshop/parley
scaffold  workshop/staging
scaffold  atlas
touch     workshop/lessons.md

# ── Sandbox (OpenShell) ──────────────────────────────────────────────────────
# .bootstrap/ and .base-image-digest are runtime artifacts (gitignored).
symlink   .openshell/Makefile
symlink   .openshell/sandbox.sh
symlink   .openshell/overlay
symlink   .openshell/dotfiles
symlink   .openshell/policy.yaml
symlink   .openshell/ssh_config
symlink   .openshell/ssh_wrapper.sh
symlink   .openshell/ssh-bin

# ── Documentation ─────────────────────────────────────────────────────────────
symlink   atlas/workflow
